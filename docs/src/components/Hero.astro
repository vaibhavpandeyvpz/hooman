---
import HeroSvg from "./HeroSvg.astro";

const base = import.meta.env.BASE_URL;

const installMethods = [
  {
    id: "vscode",
    label: "vscode",
    command: "vscode:extension/VPZ.hoomanjs-vscode",
    href: "vscode:extension/VPZ.hoomanjs-vscode",
  },
  {
    id: "curl",
    label: "curl",
    command:
      "curl -fsSL https://raw.githubusercontent.com/vaibhavpandeyvpz/hooman/main/install.sh | bash",
  },
  {
    id: "powershell",
    label: "pwsh",
    command:
      "irm https://raw.githubusercontent.com/vaibhavpandeyvpz/hooman/main/install.ps1 | iex",
  },
  {
    id: "npm",
    label: "npm",
    command: "npm i -g hoomanjs",
  },
  {
    id: "bun",
    label: "bun",
    command: "bun add -g hoomanjs",
  },
  {
    id: "npx",
    label: "npx",
    command: "npx hoomanjs",
  },
] as const;

const pillars = [
  { label: "Open source", detail: "MIT · audit everything" },
  { label: "Local-first", detail: "setup · llama.cpp · MLX" },
  { label: "BYOK", detail: "Your keys · your inference" },
  { label: "Enterprise", detail: "No telemetry · full control" },
];
---

<section class="relative overflow-hidden pt-36 pb-20 sm:pt-44 sm:pb-28">
  <!-- Sharp geometric field (SVG-only atmosphere) -->
  <svg
    class="pointer-events-none absolute inset-0 -z-10 h-full w-full opacity-40"
    aria-hidden="true"
  >
    <defs>
      <linearGradient id="heroField" x1="0%" y1="0%" x2="100%" y2="100%">
        <stop offset="0%" stop-color="#0091cd" stop-opacity="0.18"></stop>
        <stop offset="50%" stop-color="#56a0d3" stop-opacity="0.06"></stop>
        <stop offset="100%" stop-color="#007bb0" stop-opacity="0.14"></stop>
      </linearGradient>
    </defs>
    <rect width="100%" height="100%" fill="url(#heroField)"></rect>
    <g stroke="#0091cd" stroke-opacity="0.12" fill="none">
      <path d="M0 120 L180 0 L360 140 L540 20 L720 160 L900 40 L1080 180 L1260 60 L1440 200"></path>
      <path d="M0 420 L200 300 L400 440 L600 320 L800 460 L1000 340 L1200 480 L1440 360"></path>
    </g>
  </svg>

  <div class="mx-auto grid max-w-6xl grid-cols-1 items-center gap-12 px-6 lg:grid-cols-[1.05fr_0.95fr] lg:gap-10">
    <div class="reveal-target min-w-0">
      <div
        class="mb-6 inline-flex items-center gap-2 rounded-sm border border-hooman-cyan/35 bg-hooman-cyan/10 px-3 py-1 text-[11px] font-semibold uppercase tracking-[0.14em] text-hooman-face"
      >
        <span class="h-1.5 w-1.5 rounded-full bg-hooman-cyan"></span>
        Open source
      </div>

      <h1 class="text-4xl font-extrabold leading-[1.05] tracking-tight text-white sm:text-5xl lg:text-[3.4rem]">
        The <span class="gradient-text">full-stack</span> agentic ecosystem.
      </h1>

      <p class="mt-6 max-w-xl text-lg leading-relaxed text-slate-300">
        Hooman is the mature, open-source agent runtime for teams that refuse lock-in — CLI, VS Code, ACP,
        daemon channels, and Design mode on one stack. Run local with <strong class="font-medium text-white">llama.cpp</strong> &amp; <strong class="font-medium text-white">MLX</strong>, bring
        your own keys, or point at your own inference endpoints.
      </p>

      <div class="mt-7 grid grid-cols-2 gap-2 sm:grid-cols-4">
        {
          pillars.map((p) => (
            <div class="rounded-lg border border-white/10 bg-white/[0.03] px-3 py-2.5">
              <p class="text-[11px] font-semibold uppercase tracking-wider text-hooman-face">{p.label}</p>
              <p class="mt-1 text-[11px] leading-snug text-slate-500">{p.detail}</p>
            </div>
          ))
        }
      </div>

      <div
        id="install-box"
        class="mt-8 min-w-0 overflow-hidden rounded-lg border border-white/10 bg-black/50 shadow-inner"
      >
        <div class="flex min-w-0 items-center justify-between gap-3 border-b border-white/10 px-4 py-3">
          <button
            id="copy-install"
            type="button"
            class="group flex min-w-0 flex-1 items-center justify-between gap-3 text-left font-mono text-sm text-slate-100"
            title="Copy install command"
          >
            <span class="flex min-w-0 flex-1 items-center overflow-hidden">
              <span class="shrink-0 text-hooman-cyan">$</span>
              <span id="install-command" class="ml-2 truncate">{installMethods[0].command}</span>
            </span>
            <span class="copy-icon shrink-0 text-slate-400 transition group-hover:text-white" aria-hidden="true"
              >↗</span
            >
          </button>
        </div>
        <div class="flex flex-wrap items-center gap-2 px-3 py-2.5" role="tablist" aria-label="Install method">
          {
            installMethods.map((method, index) => (
              <button
                type="button"
                class:list={[
                  "install-method rounded-md px-2.5 py-1 font-mono text-[11px] transition",
                  index === 0
                    ? "border border-hooman-warning/80 text-hooman-warning"
                    : "border border-transparent text-slate-500 hover:text-slate-300",
                ]}
                data-method={method.id}
                data-command={method.command}
                data-href={"href" in method ? method.href : undefined}
                aria-pressed={index === 0 ? "true" : "false"}
              >
                {method.label}
              </button>
            ))
          }
        </div>
      </div>

      <div class="mt-5 flex flex-col gap-3 sm:flex-row sm:items-center">
        <a
          href={`${base}/getting-started/`}
          class="inline-flex items-center justify-center gap-2 rounded-md bg-gradient-to-r from-hooman-cyan via-hooman-blue to-hooman-indigo px-6 py-3 text-sm font-semibold text-ink-950 shadow-lg shadow-blue-500/25 transition hover:opacity-90"
        >
          Get started
          <span aria-hidden="true">→</span>
        </a>
        <a
          href="https://github.com/vaibhavpandeyvpz/hooman"
          target="_blank"
          rel="noreferrer"
          class="inline-flex items-center justify-center rounded-md border border-white/15 px-5 py-3 text-sm font-medium text-slate-200 transition hover:border-white/30 hover:text-white"
        >
          View source
        </a>
      </div>
    </div>

    <div class="reveal-target relative" style="transition-delay: 100ms">
      <div
        class="pointer-events-none absolute -inset-8 -z-10 bg-gradient-to-tr from-hooman-cyan/20 via-transparent to-hooman-indigo/15 blur-3xl"
        aria-hidden="true"
      >
      </div>
      <HeroSvg />
    </div>
  </div>
</section>

<script>
  const commandEl = document.getElementById("install-command");
  const copyButton = document.getElementById("copy-install");
  const copyIcon = copyButton?.querySelector(".copy-icon");
  const methodButtons = Array.from(document.querySelectorAll<HTMLButtonElement>(".install-method"));

  let activeCommand = methodButtons[0]?.dataset.command ?? "";
  let activeHref = methodButtons[0]?.dataset.href ?? "";

  const syncActionChrome = () => {
    if (!copyButton || !copyIcon) return;
    if (activeHref) {
      copyButton.title = "Install in VS Code";
      copyIcon.textContent = "↗";
    } else {
      copyButton.title = "Copy install command";
      copyIcon.textContent = "⧉";
    }
  };

  const setActive = (button: HTMLButtonElement) => {
    activeCommand = button.dataset.command ?? "";
    activeHref = button.dataset.href ?? "";
    if (commandEl) commandEl.textContent = activeCommand;
    syncActionChrome();
    for (const other of methodButtons) {
      const active = other === button;
      other.setAttribute("aria-pressed", active ? "true" : "false");
      other.classList.toggle("border-hooman-warning/80", active);
      other.classList.toggle("text-hooman-warning", active);
      other.classList.toggle("border-transparent", !active);
      other.classList.toggle("text-slate-500", !active);
    }
  };

  for (const button of methodButtons) {
    button.addEventListener("click", () => setActive(button));
  }

  syncActionChrome();

  copyButton?.addEventListener("click", async () => {
    if (activeHref) {
      window.location.href = activeHref;
      return;
    }
    try {
      await navigator.clipboard.writeText(activeCommand);
      if (copyIcon) {
        const original = copyIcon.textContent;
        copyIcon.textContent = "✓";
        setTimeout(() => {
          copyIcon.textContent = original;
        }, 1500);
      }
    } catch {
      // clipboard unavailable; no-op
    }
  });
</script>
