---
import screenshot from "../assets/screenshot-cli.png";
import { Image } from "astro:assets";

const base = import.meta.env.BASE_URL;
---

<section class="relative overflow-hidden pt-40 pb-24 sm:pt-48 sm:pb-32">
  <div
    class="pointer-events-none absolute inset-x-0 -top-40 -z-10 flex justify-center blur-3xl"
    aria-hidden="true"
  >
    <div
      class="aspect-1155/678 w-[72rem] animate-float bg-gradient-to-tr from-hooman-cyan via-hooman-blue to-hooman-indigo opacity-20"
      style="clip-path: polygon(74.1% 44.1%, 100% 61.6%, 97.5% 26.9%, 85.5% 0.1%, 80.7% 2%, 72.5% 32.5%, 60.2% 62.4%, 52.4% 68.1%, 47.5% 58.3%, 45.2% 34.5%, 27.5% 76.7%, 0.1% 64.9%, 17.9% 100%, 27.6% 76.8%, 76.1% 97.7%, 74.1% 44.1%)"
    >
    </div>
  </div>

  <div class="mx-auto grid max-w-6xl grid-cols-1 items-center gap-16 px-6 lg:grid-cols-2">
    <div class="reveal-target">
      <div
        class="mb-6 inline-flex items-center gap-2 rounded-full border border-white/10 bg-white/5 px-3 py-1 text-xs font-medium text-slate-300"
      >
        <span class="h-1.5 w-1.5 rounded-full bg-hooman-cyan"></span>
        Open source · MIT licensed
      </div>
      <h1 class="text-4xl font-extrabold tracking-tight text-white sm:text-5xl lg:text-6xl">
        The <span class="gradient-text">hackable</span>, local-first AI agent
      </h1>
      <p class="mt-6 max-w-xl text-lg leading-relaxed text-slate-300">
        Hooman reads your codebase, edits files, and runs commands — from your terminal, VS Code, or any
        Agent Client Protocol client. Bring your own model. Your config, keys, and sessions never leave
        <code class="rounded bg-white/10 px-1.5 py-0.5 font-mono text-sm text-hooman-blush">~/.hooman</code>.
      </p>

      <div class="mt-8 flex flex-col gap-4 sm:flex-row sm:items-center">
        <button
          id="copy-install"
          type="button"
          class="group flex items-center justify-between gap-4 rounded-xl border border-white/10 bg-black/40 px-4 py-3 font-mono text-sm text-slate-100 shadow-inner transition hover:border-white/20"
        >
          <span><span class="text-hooman-cyan">$</span> npx hoomanjs</span>
          <span class="copy-icon text-slate-400 transition group-hover:text-white" aria-hidden="true">⧉</span>
        </button>
        <a
          href={`${base}/getting-started/`}
          class="inline-flex items-center justify-center gap-2 rounded-xl bg-gradient-to-r from-hooman-cyan via-hooman-blue to-hooman-indigo px-6 py-3 text-sm font-semibold text-ink-950 shadow-lg shadow-blue-500/25 transition hover:opacity-90"
        >
          Read the docs
          <span aria-hidden="true">→</span>
        </a>
      </div>
      <p class="mt-3 text-xs text-slate-500">Requires Node.js ≥ 24. Works with Anthropic, OpenAI, Google, Ollama, and more.</p>
    </div>

    <div class="reveal-target relative" style="transition-delay: 120ms">
      <div
        class="absolute -inset-6 -z-10 rounded-[2rem] bg-gradient-to-tr from-hooman-cyan/20 via-hooman-blue/10 to-hooman-indigo/20 blur-2xl"
      >
      </div>
      <Image src={screenshot} alt="Hooman running in the terminal" class="w-full" loading="eager" />
    </div>
  </div>
</section>

<script>
  const button = document.getElementById("copy-install");
  button?.addEventListener("click", async () => {
    try {
      await navigator.clipboard.writeText("npx hoomanjs");
      const icon = button.querySelector(".copy-icon");
      if (icon) {
        const original = icon.textContent;
        icon.textContent = "✓";
        setTimeout(() => {
          icon.textContent = original;
        }, 1500);
      }
    } catch {
      // clipboard unavailable; no-op
    }
  });
</script>
