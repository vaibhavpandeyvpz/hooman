---
import BrandIcon from "./BrandIcon.astro";

const base = import.meta.env.BASE_URL;

const surfaces = [
  {
    icon: "terminal",
    title: "Terminal",
    description:
      "hooman setup for first-run config, hooman chat for a stateful Ink-powered TUI, hooman exec for one-shot prompts, and hooman daemon for channel-driven automation.",
    href: `${base}/guides/cli/`,
    cta: "Explore the CLI",
  },
  {
    icon: "visualstudiocode",
    title: "VS Code",
    description:
      "A native chat panel in the activity bar: streaming markdown and Mermaid, tool-call cards, background terminals, Changes with diff/keep/undo, plan checklists, and turn revert.",
    href: `${base}/guides/vscode/`,
    cta: "VS Code extension",
  },
  {
    icon: "acp",
    title: "ACP clients",
    description:
      "hooman acp runs Hooman as an Agent Client Protocol agent over stdio for Zed and any other ACP-compatible editor.",
    href: `${base}/guides/acp/`,
    cta: "About ACP",
  },
];

const slashCommands = [
  "/model",
  "/mode",
  "/effort",
  "/sessions",
  "/tasks",
  "/compact",
  "/config",
];

const cliCommands = [
  {
    cmd: "hooman setup",
    hint: "First-run inference + search",
  },
  {
    cmd: "hooman chat",
    hint: "Stateful Ink TUI",
  },
  {
    cmd: "hooman exec",
    hint: "One-shot for scripts & CI",
  },
  {
    cmd: "hooman daemon",
    hint: "Channel-driven automation",
  },
];

const vscodeCapabilities = [
  {
    label: "Streaming chat",
    detail: "Markdown, Mermaid, collapsible reasoning",
    accent: "from-hooman-cyan to-hooman-blue",
  },
  {
    label: "Tool cards",
    detail: "Shell, edits, search — stop background jobs",
    accent: "from-hooman-blue to-hooman-indigo",
  },
  {
    label: "Changes",
    detail: "Per-file diffs · Keep all · Undo all · revert",
    accent: "from-hooman-cyan to-hooman-indigo",
  },
  {
    label: "Plan & pickers",
    detail: "Pinned checklist · model · mode · effort · Yolo",
    accent: "from-hooman-warning/80 to-hooman-blue",
  },
];

const modes = [
  { name: "Agent", active: true },
  { name: "Plan", active: false },
  { name: "Ask", active: false },
  { name: "Design", active: false },
];
---

<section id="surfaces" class="relative py-24 sm:py-32">
  <div class="mx-auto max-w-6xl px-6">
    <div class="reveal-target mx-auto max-w-2xl text-center">
      <h2 class="text-3xl font-bold tracking-tight text-white sm:text-4xl">One runtime. Every surface.</h2>
      <p class="mt-4 text-lg text-slate-400">
        Terminal, VS Code, and any ACP client share the same local config, sessions, skills, and approvals.
      </p>
      <a
        href="https://www.producthunt.com/products/hooman-open-source-agent-runtime?embed=true&utm_source=badge-featured&utm_medium=badge&utm_campaign=badge-hooman"
        target="_blank"
        rel="noopener noreferrer"
        class="mt-6 inline-flex transition hover:opacity-90"
      >
        <img
          src="https://api.producthunt.com/widgets/embed-image/v1/featured.svg?post_id=1195793&theme=dark&t=1784169092492"
          alt="Hooman - Own your AI agent stack — local, open source and extensible | Product Hunt"
          width="250"
          height="54"
          loading="lazy"
        />
      </a>
    </div>

    <div class="mt-16 grid grid-cols-1 gap-6 lg:grid-cols-3">
      {
        surfaces.map((s, i) => (
          <a
            href={s.href}
            class="reveal-target group relative flex flex-col rounded-lg border border-white/10 bg-white/[0.03] p-8 transition duration-300 hover:-translate-y-1 hover:border-white/20 hover:bg-white/[0.06]"
            style={`transition-delay: ${i * 100}ms`}
          >
            <div class="flex h-12 w-12 items-center justify-center rounded-lg bg-gradient-to-br from-hooman-cyan/20 to-hooman-indigo/20 text-white">
              <BrandIcon slug={s.icon} class="h-6 w-6" />
            </div>
            <h3 class="mt-6 text-xl font-semibold text-white">{s.title}</h3>
            <p class="mt-3 text-sm leading-relaxed text-slate-400">{s.description}</p>
            <span class="mt-6 inline-flex items-center gap-1.5 text-sm font-medium text-hooman-blush">
              {s.cta}
              <span class="transition group-hover:translate-x-1" aria-hidden="true">→</span>
            </span>
          </a>
        ))
      }
    </div>

    <!-- CLI -->
    <div class="reveal-target relative mt-16 overflow-hidden rounded-lg border border-white/10 bg-black/40">
      <div class="border-b border-white/10 px-6 py-4 sm:px-10">
        <div class="flex flex-wrap items-center justify-between gap-3">
          <div class="flex items-center gap-2.5">
            <BrandIcon slug="terminal" class="h-4 w-4 text-hooman-face" />
            <p class="text-sm font-semibold text-white">CLI</p>
            <span class="rounded-sm border border-white/10 bg-white/5 px-2 py-0.5 font-mono text-[10px] text-slate-400"
              >hooman chat</span
            >
          </div>
          <a
            href={`${base}/guides/cli/`}
            class="text-xs font-medium text-hooman-blush transition hover:text-white"
          >
            CLI guide →
          </a>
        </div>
      </div>

      <div class="px-6 py-10 sm:px-10 lg:px-12">
        <img
          src={`${base}/screenshots/ask-mode.png`}
          alt="Hooman running in the terminal"
          class="mx-auto h-auto w-full max-w-2xl rounded-lg shadow-2xl shadow-black/60"
          loading="lazy"
          decoding="async"
        />
      </div>

      <div class="border-t border-white/10 bg-ink-950/80 px-6 py-8 sm:px-10 lg:px-12">
        <div class="mx-auto max-w-4xl space-y-6">
          <!-- Live status bar mock -->
          <div
            class="overflow-x-auto rounded-md border border-white/10 bg-black/50 px-4 py-3 font-mono text-[11px] leading-relaxed text-slate-400 sm:text-xs"
            aria-hidden="true"
          >
            <p class="whitespace-nowrap">
              <span class="text-slate-500">model:</span>
              <span class="text-white"> GPT 5.4</span>
              <span class="text-slate-600"> · </span>
              <span class="text-slate-500">effort:</span>
              <span class="text-hooman-face"> low</span>
              <span class="text-slate-600"> · </span>
              <span class="text-slate-500">mode:</span>
              <span class="text-hooman-cyan"> ask</span>
              <span class="text-slate-600"> · </span>
              <span class="text-slate-500">yolo:</span>
              <span class="text-hooman-face"> off</span>
            </p>
            <p class="mt-1 whitespace-nowrap">
              <span class="text-slate-500">context:</span>
              <span class="text-hooman-face"> 1%</span>
              <span class="text-slate-600"> · </span>
              <span class="text-slate-500">tokens:</span>
              <span class="text-hooman-face"> 11k in, 195 out, 108 tok/s</span>
              <span class="text-slate-600"> · </span>
              <span class="text-slate-500">cost:</span>
              <span class="text-hooman-face"> $0.05</span>
            </p>
          </div>

          <!-- Slash commands -->
          <div>
            <p class="mb-2.5 text-[11px] font-semibold uppercase tracking-[0.14em] text-slate-500">
              Slash commands
            </p>
            <div class="flex flex-wrap gap-2">
              {
                slashCommands.map((cmd) => (
                  <code class="rounded-md border border-white/10 bg-white/[0.04] px-2.5 py-1 font-mono text-xs text-hooman-face transition hover:border-hooman-cyan/40 hover:bg-hooman-cyan/10 hover:text-white">
                    {cmd}
                  </code>
                ))
              }
            </div>
          </div>

          <!-- Entry points -->
          <div class="grid grid-cols-1 gap-2 sm:grid-cols-3">
            {
              cliCommands.map((c) => (
                <div class="flex items-baseline gap-2 rounded-md border border-white/10 bg-white/[0.03] px-3.5 py-3">
                  <code class="font-mono text-xs font-semibold text-white">{c.cmd}</code>
                  <span class="truncate text-[11px] text-slate-500">{c.hint}</span>
                </div>
              ))
            }
          </div>
        </div>
      </div>
    </div>

    <!-- VS Code -->
    <div class="reveal-target relative mt-8 overflow-hidden rounded-lg border border-white/10 bg-black/40">
      <div class="border-b border-white/10 px-6 py-4 sm:px-10">
        <div class="flex flex-wrap items-center justify-between gap-3">
          <div class="flex items-center gap-2.5">
            <BrandIcon slug="visualstudiocode" class="h-4 w-4 text-hooman-face" />
            <p class="text-sm font-semibold text-white">VS Code</p>
            <span class="rounded-sm border border-white/10 bg-white/5 px-2 py-0.5 font-mono text-[10px] text-slate-400"
              >hooman acp</span
            >
          </div>
          <a
            href={`${base}/guides/vscode/`}
            class="text-xs font-medium text-hooman-blush transition hover:text-white"
          >
            Extension guide →
          </a>
        </div>
      </div>

      <div class="px-6 py-10 sm:px-10 lg:px-12">
        <img
          src={`${base}/screenshots/agent-mode.png`}
          alt="Hooman chat panel in VS Code"
          class="mx-auto h-auto w-full max-w-5xl rounded-lg shadow-2xl shadow-black/60"
          loading="lazy"
          decoding="async"
        />
      </div>

      <div class="border-t border-white/10 bg-ink-950/80 px-6 py-8 sm:px-10 lg:px-12">
        <div class="mx-auto max-w-5xl space-y-6">
          <!-- Composer chrome mock -->
          <div
            class="flex flex-wrap items-center gap-2 rounded-md border border-white/10 bg-black/50 p-2.5"
            aria-hidden="true"
          >
            <span
              class="rounded-md border border-white/10 bg-white/5 px-2.5 py-1 text-[11px] font-medium text-slate-300"
              >GPT 5.4</span
            >
            <span
              class="rounded-md border border-white/10 bg-white/5 px-2.5 py-1 text-[11px] font-medium text-slate-400"
              >low</span
            >
            <div class="flex items-center gap-1 rounded-md border border-white/10 bg-black/40 p-0.5">
              {
                modes.map((m) => (
                  <span
                    class:list={[
                      "rounded-sm px-2.5 py-1 text-[11px] font-medium",
                      m.active
                        ? "bg-hooman-cyan/20 text-hooman-face"
                        : "text-slate-500",
                    ]}
                  >
                    {m.name}
                  </span>
                ))
              }
            </div>
            <span
              class="rounded-md border border-white/10 bg-white/5 px-2.5 py-1 text-[11px] font-medium text-slate-400"
              >Yolo</span
            >
            <div class="ml-auto flex items-center gap-2">
              <span class="text-[11px] text-slate-500">Changes 26</span>
              <span
                class="rounded-md border border-white/15 bg-white/5 px-2 py-1 text-[11px] font-medium text-slate-300"
                >Undo all</span
              >
              <span
                class="rounded-md bg-hooman-cyan px-2 py-1 text-[11px] font-medium text-white"
                >Keep all</span
              >
            </div>
          </div>

          <!-- Capability rail -->
          <div class="grid grid-cols-1 gap-px overflow-hidden rounded-lg border border-white/10 bg-white/10 sm:grid-cols-2 lg:grid-cols-4">
            {
              vscodeCapabilities.map((c) => (
                <div class="bg-ink-950 p-5">
                  <div class={`h-1 w-8 bg-gradient-to-r ${c.accent}`} />
                  <p class="mt-3 text-sm font-semibold text-white">{c.label}</p>
                  <p class="mt-1.5 text-xs leading-relaxed text-slate-400">{c.detail}</p>
                </div>
              ))
            }
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
