---
import BrandIcon from "./BrandIcon.astro";
import { Image } from "astro:assets";
import vscodeScreenshot from "../assets/screenshot-vscode.png";

const base = import.meta.env.BASE_URL;

const surfaces = [
  {
    icon: "terminal",
    title: "Terminal",
    description:
      "hooman chat for a stateful Ink-powered TUI, hooman exec for one-shot prompts, and hooman daemon for channel-driven automation.",
    href: `${base}/guides/cli/`,
    cta: "Explore the CLI",
  },
  {
    icon: "visualstudiocode",
    title: "VS Code",
    description:
      "A native chat panel in the activity bar: streaming markdown, tool-call cards, a Changes panel with diff/keep/undo, and plan checklists.",
    href: `${base}/guides/vscode/`,
    cta: "VS Code extension",
  },
  {
    icon: "acp",
    title: "ACP clients",
    description:
      "hooman acp runs Hooman as an Agent Client Protocol agent over stdio for Zed and any other ACP-compatible editor.",
    href: `${base}/guides/acp/`,
    cta: "About ACP",
  },
];

const vscodeHighlights = {
  left: [
    {
      title: "Streaming chat, native to the editor",
      description: "Markdown renders live in the activity bar as the agent thinks, with collapsible reasoning.",
    },
    {
      title: "Tool-call cards",
      description: "See every shell command, file edit, and search the agent runs, with inline permission prompts.",
    },
  ],
  right: [
    {
      title: "Changes panel",
      description: "Per-file diffs with one-click keep or undo, backed by pre-edit baselines.",
    },
    {
      title: "Plan checklists & slash commands",
      description: "Pinned plan tracking plus /model, /mode, /sessions, and more without leaving the panel.",
    },
  ],
};
---

<section id="surfaces" class="relative py-24 sm:py-32">
  <div class="mx-auto max-w-6xl px-6">
    <div class="reveal-target mx-auto max-w-2xl text-center">
      <h2 class="text-3xl font-bold tracking-tight text-white sm:text-4xl">Meets you where you work</h2>
      <p class="mt-4 text-lg text-slate-400">
        One agent, one local config, three ways in — pick whichever fits the moment.
      </p>
    </div>

    <div class="mt-16 grid grid-cols-1 gap-6 lg:grid-cols-3">
      {
        surfaces.map((s, i) => (
          <a
            href={s.href}
            class="reveal-target group relative flex flex-col rounded-2xl border border-white/10 bg-white/[0.03] p-8 transition duration-300 hover:-translate-y-1 hover:border-white/20 hover:bg-white/[0.06]"
            style={`transition-delay: ${i * 100}ms`}
          >
            <div class="flex h-12 w-12 items-center justify-center rounded-xl bg-gradient-to-br from-hooman-cyan/20 to-hooman-indigo/20 text-white">
              <BrandIcon slug={s.icon} class="h-6 w-6" />
            </div>
            <h3 class="mt-6 text-xl font-semibold text-white">{s.title}</h3>
            <p class="mt-3 text-sm leading-relaxed text-slate-400">{s.description}</p>
            <span class="mt-6 inline-flex items-center gap-1.5 text-sm font-medium text-hooman-blush">
              {s.cta}
              <span class="transition group-hover:translate-x-1" aria-hidden="true">→</span>
            </span>
          </a>
        ))
      }
    </div>

    <div class="reveal-target relative mt-16 overflow-hidden rounded-2xl border border-white/10 bg-black/40 px-6 py-12 sm:px-10 lg:px-12">
      <div class="grid items-center gap-10 lg:grid-cols-[1fr_auto_1fr] lg:gap-8">
        <ul class="space-y-6 lg:text-right">
          {
            vscodeHighlights.left.map((h) => (
              <li class="lg:flex lg:flex-col lg:items-end">
                <p class="font-medium text-white">{h.title}</p>
                <p class="mt-1 text-sm leading-relaxed text-slate-400">{h.description}</p>
              </li>
            ))
          }
        </ul>

        <Image
          src={vscodeScreenshot}
          alt="Hooman chat panel in VS Code"
          class="mx-auto h-auto w-full max-w-xs rounded-lg shadow-2xl shadow-black/60"
        />

        <ul class="space-y-6">
          {
            vscodeHighlights.right.map((h) => (
              <li>
                <p class="font-medium text-white">{h.title}</p>
                <p class="mt-1 text-sm leading-relaxed text-slate-400">{h.description}</p>
              </li>
            ))
          }
        </ul>
      </div>
    </div>
  </div>
</section>
