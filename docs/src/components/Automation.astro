---
const base = import.meta.env.BASE_URL;

const servers = [
  { name: "cronmcp", description: "Schedule recurring prompts and automations.", href: "https://github.com/vaibhavpandeyvpz/cronmcp" },
  { name: "jiraxmcp", description: "Search issues, update tickets, drive sprints.", href: "https://github.com/vaibhavpandeyvpz/jiraxmcp" },
  { name: "slackxmcp", description: "Read channel context, draft updates, post actions.", href: "https://github.com/vaibhavpandeyvpz/slackxmcp" },
  { name: "tgfmcp", description: "Route notifications through Telegram bot workflows.", href: "https://github.com/vaibhavpandeyvpz/tgfmcp" },
  { name: "wappmcp", description: "WhatsApp Web messaging for customer/team automations.", href: "https://github.com/vaibhavpandeyvpz/wappmcp" },
];
---

<section id="automation" class="relative py-24 sm:py-32">
  <div class="mx-auto max-w-6xl px-6">
    <div class="grid grid-cols-1 gap-16 lg:grid-cols-2 lg:items-center">
      <div class="reveal-target">
        <div class="inline-flex items-center gap-2 rounded-full border border-white/10 bg-white/5 px-3 py-1 text-xs font-medium text-slate-300">
          <span class="h-1.5 w-1.5 rounded-full bg-hooman-indigo"></span>
          hooman daemon
        </div>
        <h2 class="mt-6 text-3xl font-bold tracking-tight text-white sm:text-4xl">
          Event-driven automation, not just chat
        </h2>
        <p class="mt-4 text-lg leading-relaxed text-slate-400">
          <code class="rounded bg-white/10 px-1.5 py-0.5 font-mono text-sm text-hooman-blush">hooman daemon</code> subscribes
          to MCP servers that advertise the <code class="rounded bg-white/10 px-1.5 py-0.5 font-mono text-sm text-hooman-blush">hooman/channel</code>
          capability, turning notifications from schedulers, ticket trackers, and chat platforms into agent
          prompts — with the same tool approval model as chat and exec.
        </p>
        <a
          href={`${base}/guides/mcp/`}
          class="mt-8 inline-flex items-center gap-2 text-sm font-semibold text-hooman-blush transition hover:text-white"
        >
          Read about MCP channels
          <span aria-hidden="true">→</span>
        </a>
      </div>

      <div class="reveal-target grid grid-cols-1 gap-3" style="transition-delay: 120ms">
        {
          servers.map((s) => (
            <a
              href={s.href}
              target="_blank"
              rel="noreferrer"
              class="group flex items-center justify-between rounded-xl border border-white/10 bg-white/[0.03] px-5 py-4 transition hover:border-white/20 hover:bg-white/[0.06]"
            >
              <div>
                <p class="font-mono text-sm font-semibold text-white">{s.name}</p>
                <p class="mt-1 text-xs text-slate-400">{s.description}</p>
              </div>
              <span class="text-slate-500 transition group-hover:translate-x-1 group-hover:text-white" aria-hidden="true">→</span>
            </a>
          ))
        }
      </div>
    </div>
  </div>
</section>
