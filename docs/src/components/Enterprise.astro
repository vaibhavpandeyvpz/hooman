---
const base = import.meta.env.BASE_URL;

const points = [
  {
    title: "MIT licensed, fully auditable",
    description:
      "No SaaS tax on the runtime. Fork it, vendor it, ship it inside your perimeter — the agent stack is yours.",
  },
  {
    title: "BYOK or your own endpoints",
    description:
      "Anthropic, OpenAI, Azure, Bedrock, OpenRouter, and more — or point OpenAI-compatible base URLs at private gateways and vLLM clusters.",
  },
  {
    title: "Local by default",
    description:
      "llama.cpp GGUF and Apple Silicon MLX presets download on demand. Zero API keys required to start coding.",
  },
  {
    title: "No account. No telemetry.",
    description:
      "Keys, sessions, skills, and MCP config live under ~/.hooman (and optional .hooman/ overlays). Nothing phones home.",
  },
];
---

<section id="enterprise" class="relative py-24 sm:py-32">
  <div class="mx-auto max-w-6xl px-6">
    <div class="reveal-target grid gap-12 lg:grid-cols-[0.9fr_1.1fr] lg:items-end">
      <div>
        <p class="text-[11px] font-semibold uppercase tracking-[0.16em] text-hooman-face">
          Enterprise-friendly
        </p>
        <h2 class="mt-3 text-3xl font-bold tracking-tight text-white sm:text-4xl">
          Built for teams that need control, not another cloud agent.
        </h2>
        <p class="mt-4 text-lg leading-relaxed text-slate-400">
          Licensing, data residency, and model choice are first-class — not afterthoughts bolted onto a freemium chat.
        </p>
        <a
          href={`${base}/guides/configuration/models/`}
          class="mt-8 inline-flex items-center gap-2 text-sm font-semibold text-hooman-blush transition hover:text-white"
        >
          Configure models &amp; endpoints
          <span aria-hidden="true">→</span>
        </a>
      </div>

      <div class="grid grid-cols-1 gap-px overflow-hidden rounded-lg border border-white/10 bg-white/10 sm:grid-cols-2">
        {
          points.map((p, i) => (
            <div
              class="reveal-target bg-ink-950 p-7"
              style={`transition-delay: ${(i % 2) * 80}ms`}
            >
              <div class="h-1 w-8 bg-gradient-to-r from-hooman-cyan to-hooman-indigo"></div>
              <h3 class="mt-4 text-base font-semibold text-white">{p.title}</h3>
              <p class="mt-2 text-sm leading-relaxed text-slate-400">{p.description}</p>
            </div>
          ))
        }
      </div>
    </div>
  </div>
</section>
