---
const base = import.meta.env.BASE_URL;
const year = new Date().getFullYear();
---

<footer class="relative border-t border-white/10 py-16">
  <div class="mx-auto max-w-6xl px-6">
    <div class="reveal-target flex flex-col items-center justify-center gap-4 rounded-2xl border border-white/10 bg-gradient-to-br from-white/[0.04] to-transparent p-10 text-center">
      <h2 class="text-2xl font-bold text-white sm:text-3xl">Ready to hack on your own agent?</h2>
      <p class="max-w-xl text-slate-400">Local-first, MIT licensed, and built to be read. Start in a terminal in under a minute.</p>
      <div class="mt-2 flex flex-wrap items-center justify-center gap-4">
        <a
          href={`${base}/getting-started/`}
          class="rounded-full bg-gradient-to-r from-hooman-cyan via-hooman-blue to-hooman-indigo px-6 py-3 text-sm font-semibold text-ink-950 shadow-lg shadow-blue-500/25 transition hover:opacity-90"
        >
          Get Started
        </a>
        <a
          href="https://github.com/vaibhavpandeyvpz/hooman"
          target="_blank"
          rel="noreferrer"
          class="rounded-full border border-white/15 px-6 py-3 text-sm font-semibold text-slate-200 transition hover:border-white/30 hover:bg-white/5"
        >
          Star on GitHub
        </a>
      </div>
    </div>

    <div class="mt-16 flex flex-col items-center justify-between gap-6 border-t border-white/10 pt-8 text-sm text-slate-500 sm:flex-row">
      <div class="flex items-center gap-2">
        <img src={`${base}/favicon.svg`} alt="Hooman" class="h-5 w-5" />
        <span>© {year} Vaibhav Pandey. MIT Licensed.</span>
      </div>
      <div class="flex items-center gap-6">
        <a href="https://github.com/vaibhavpandeyvpz/hooman" target="_blank" rel="noreferrer" class="transition hover:text-white">GitHub</a>
        <a href="https://www.npmjs.com/package/hoomanjs" target="_blank" rel="noreferrer" class="transition hover:text-white">npm</a>
        <a href={`${base}/guides/vscode/`} class="transition hover:text-white">VS Code</a>
        <a href="https://vaibhavpandey.com" target="_blank" rel="noreferrer" class="transition hover:text-white">Author</a>
      </div>
    </div>
  </div>
</footer>
