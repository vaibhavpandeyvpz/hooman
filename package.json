    "exa-js": "^2.14.0",
    "fastq": "^1.20.1",
    "fflate": "^0.8.3",
    "gray-matter": "^2.0.1",
    "handlebars": "^4.7.9",
    "ignore": "^7.0.5",
    "ink": "^7.0.0",
    "ink-ansi": "^1.0.0",
    "ink-select-input": "^6.2.0",
    "ink-text-input": "^6.0.0",
    "ink-use-mouse": "^1.0.0",
    "jsdom": "^29.0.2",
    "lodash": "^4.18.1",
    "luxon": "^3.7.2",
    "marked": "^18.0.2",
    "millify": "^6.1.0",
    "ollama": "^0.6.3",
    "openai": "^6.45.0",
    "openfig-core": "^0.3.7",
    "pdf-lib": "^1.17.1",
