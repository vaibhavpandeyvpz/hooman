{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run Hooman Extension",
      "type": "extensionHost",
      "request": "launch",
      "args": ["--extensionDevelopmentPath=${workspaceFolder}/src/vscode"],
      "outFiles": ["${workspaceFolder}/src/vscode/out/**/*.js"],
      "preLaunchTask": "${defaultBuildTask}"
    }
  ]
}
